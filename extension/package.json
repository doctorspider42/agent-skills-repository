{
  "name": "agent-skills-repository",
  "displayName": "Agent Skills Repository",
  "description": "Browse, install and update Agent skills from your private repository.",
  "version": "0.3.0",
  "publisher": "doctorspider",
  "license": "MIT",
    "repository": {
    "type": "git",
    "url": "https://github.com/doctorspider42/agent-skills-repository.git",
    "directory": "extension"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onView:agentSkillsExplorer",
    "onView:agentSkillsAgentsExplorer",
    "onCommand:agentSkills.testConnection",
    "onCommand:agentSkills.openSettings",
    "onCommand:agentSkills.preview",
    "onCommand:agentSkills.agents.preview"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Agent Skills Repository",
      "properties": {
        "agentSkills.apiUrl": {
          "type": "string",
          "default": "",
          "description": "Base URL of the Skills API (e.g. https://skills.internal.example.com).",
          "scope": "machine-overridable"
        },
        "agentSkills.authMode": {
          "type": "string",
          "enum": ["apiKey", "entra"],
          "default": "apiKey",
          "enumDescriptions": [
            "Authenticate with a shared API key (legacy).",
            "Sign in with your Microsoft / company account via Entra ID (Azure AD)."
          ],
          "description": "How the extension authenticates against the Skills API.",
          "scope": "machine-overridable"
        },
        "agentSkills.entra.tenantId": {
          "type": "string",
          "default": "",
          "description": "Microsoft Entra ID tenant ID (GUID). Used when authMode = 'entra'.",
          "scope": "machine-overridable"
        },
        "agentSkills.entra.clientId": {
          "type": "string",
          "default": "",
          "description": "Optional: client ID of the VS Code app registration in your tenant. Leave empty to use VS Code's built-in Microsoft app.",
          "scope": "machine-overridable"
        },
        "agentSkills.entra.scope": {
          "type": "string",
          "default": "",
          "description": "OAuth scope requested when signing in (e.g. api://<api-app-id>/Skills.Access). Required when authMode = 'entra'.",
          "scope": "machine-overridable"
        },
        "agentSkills.defaultScope": {
          "type": "string",
          "enum": ["global", "project"],
          "default": "project",
          "description": "Where new skills are installed when no scope is chosen interactively."
        },
        "agentSkills.projectSkillsPath": {
          "type": "string",
          "default": ".github/skills",
          "description": "Project (local) — path inside the workspace used for the 'project' scope when installing skills.",
          "scope": "resource"
        },
        "agentSkills.projectAgentsPath": {
          "type": "string",
          "default": ".github/agents",
          "description": "Project (local) — path inside the workspace used for the 'project' scope when installing agents.",
          "scope": "resource"
        },
        "agentSkills.globalSkillsPath": {
          "type": "string",
          "default": "",
          "description": "Global — absolute path used for the 'global' scope when installing skills. Empty = ${HOME}/.claude/skills.",
          "scope": "machine"
        },
        "agentSkills.globalAgentsPath": {
          "type": "string",
          "default": "",
          "description": "Global — absolute path used for the 'global' scope when installing agents. Empty = ${HOME}/.claude/agents.",
          "scope": "machine"
        },
        "agentSkills.requestTimeoutMs": {
          "type": "number",
          "default": 30000,
          "description": "HTTP request timeout for API calls (ms)."
        }
      }
    },
    "commands": [
      {
        "command": "agentSkills.refresh",
        "title": "Agent Skills: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "agentSkills.openSettings",
        "title": "Agent Skills: Open Settings",
        "icon": "$(gear)"
      },
      {
        "command": "agentSkills.testConnection",
        "title": "Agent Skills: Test Connection",
        "icon": "$(plug)"
      },
      {
        "command": "agentSkills.setApiKey",
        "title": "Agent Skills: Set API Key"
      },
      {
        "command": "agentSkills.clearApiKey",
        "title": "Agent Skills: Clear API Key"
      },
      {
        "command": "agentSkills.signIn",
        "title": "Agent Skills: Sign in with Microsoft"
      },
      {
        "command": "agentSkills.signOut",
        "title": "Agent Skills: Sign out"
      },
      {
        "command": "agentSkills.preview",
        "title": "Agent Skills: Preview Skill",
        "icon": "$(preview)"
      },
      {
        "command": "agentSkills.install",
        "title": "Install Skill",
        "icon": "$(cloud-download)"
      },
      {
        "command": "agentSkills.uninstall",
        "title": "Uninstall Skill",
        "icon": "$(trash)"
      },
      {
        "command": "agentSkills.update",
        "title": "Update Skill",
        "icon": "$(sync)"
      },
      {
        "command": "agentSkills.openSkillFolder",
        "title": "Reveal in Explorer"
      },
      {
        "command": "agentSkills.agents.preview",
        "title": "Agent Skills: Preview Agent",
        "icon": "$(preview)"
      },
      {
        "command": "agentSkills.agents.install",
        "title": "Install Agent",
        "icon": "$(cloud-download)"
      },
      {
        "command": "agentSkills.agents.uninstall",
        "title": "Uninstall Agent",
        "icon": "$(trash)"
      },
      {
        "command": "agentSkills.agents.update",
        "title": "Update Agent",
        "icon": "$(sync)"
      },
      {
        "command": "agentSkills.agents.openFolder",
        "title": "Reveal in Explorer"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agentSkills",
          "title": "Agent Skills Repository",
          "icon": "resources/skills.svg"
        }
      ]
    },
    "views": {
      "agentSkills": [
        {
          "id": "agentSkillsExplorer",
          "name": "Skills",
          "icon": "resources/skills.svg",
          "contextualTitle": "Agent Skills Repository"
        },
        {
          "id": "agentSkillsAgentsExplorer",
          "name": "Agents",
          "icon": "resources/skills.svg",
          "contextualTitle": "Agent Skills Repository"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "agentSkills.refresh",
          "when": "view == agentSkillsExplorer",
          "group": "navigation@1"
        },
        {
          "command": "agentSkills.testConnection",
          "when": "view == agentSkillsExplorer",
          "group": "navigation@2"
        },
        {
          "command": "agentSkills.openSettings",
          "when": "view == agentSkillsExplorer",
          "group": "navigation@3"
        },
        {
          "command": "agentSkills.refresh",
          "when": "view == agentSkillsAgentsExplorer",
          "group": "navigation@1"
        },
        {
          "command": "agentSkills.testConnection",
          "when": "view == agentSkillsAgentsExplorer",
          "group": "navigation@2"
        },
        {
          "command": "agentSkills.openSettings",
          "when": "view == agentSkillsAgentsExplorer",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "agentSkills.preview",
          "when": "view == agentSkillsExplorer && viewItem == skill.notInstalled",
          "group": "inline@0"
        },
        {
          "command": "agentSkills.install",
          "when": "view == agentSkillsExplorer && viewItem == skill.notInstalled",
          "group": "inline@1"
        },
        {
          "command": "agentSkills.update",
          "when": "view == agentSkillsExplorer && viewItem == skill.updateAvailable",
          "group": "inline"
        },
        {
          "command": "agentSkills.uninstall",
          "when": "view == agentSkillsExplorer && viewItem =~ /^skill\\.(installed|updateAvailable)$/",
          "group": "inline"
        },
        {
          "command": "agentSkills.openSkillFolder",
          "when": "view == agentSkillsExplorer && viewItem =~ /^skill\\.(installed|updateAvailable)$/",
          "group": "1_navigation"
        },
        {
          "command": "agentSkills.agents.preview",
          "when": "view == agentSkillsAgentsExplorer && viewItem == agent.notInstalled",
          "group": "inline@0"
        },
        {
          "command": "agentSkills.agents.install",
          "when": "view == agentSkillsAgentsExplorer && viewItem == agent.notInstalled",
          "group": "inline@1"
        },
        {
          "command": "agentSkills.agents.update",
          "when": "view == agentSkillsAgentsExplorer && viewItem == agent.updateAvailable",
          "group": "inline"
        },
        {
          "command": "agentSkills.agents.uninstall",
          "when": "view == agentSkillsAgentsExplorer && viewItem =~ /^agent\\.(installed|updateAvailable)$/",
          "group": "inline"
        },
        {
          "command": "agentSkills.agents.openFolder",
          "when": "view == agentSkillsAgentsExplorer && viewItem =~ /^agent\\.(installed|updateAvailable)$/",
          "group": "1_navigation"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsc -p ./",
    "watch": "tsc -p ./ -w",
    "typecheck": "tsc -p ./ --noEmit",
    "package": "vsce package"
  },
  "dependencies": {
    "adm-zip": "^0.5.12",
    "axios": "^1.7.2"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/node": "^18.19.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.4.5"
  }
}
