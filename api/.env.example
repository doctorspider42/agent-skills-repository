# --- Server ---
PORT=3000

# --- Auth ---
# Which auth scheme(s) the API accepts:
#   apikey -> only the legacy x-api-key / Bearer-string header
#   entra  -> only Microsoft Entra ID (Azure AD) JWTs
#   both   -> accept either (recommended during migration)
AUTH_MODE=apikey

# Comma-separated list of valid API keys. In production rotate via your secret store.
# Required when AUTH_MODE is 'apikey' or 'both'.
API_KEYS=dev-key-change-me

# --- Entra ID (Azure AD) ---
# Required when AUTH_MODE is 'entra' or 'both'.
# Tenant ID (single-tenant) of your organisation. GUID.
ENTRA_TENANT_ID=
# App ID URI of the API App Registration (e.g. api://<api-app-id>) — must match the 'aud' claim.
ENTRA_API_AUDIENCE=
# Optional: comma-separated tenant allow-list (defaults to ENTRA_TENANT_ID).
ENTRA_ALLOWED_TENANTS=
# Optional: required delegated scope ('scp') or app role ('roles') — leave empty to skip.
ENTRA_REQUIRED_SCOPE=Skills.Access
# Optional: clock skew tolerance in seconds (default 300 = 5 min).
ENTRA_CLOCK_TOLERANCE_SECONDS=300

# --- Azure Blob Storage ---
# Default = local Azurite emulator (run `npx azurite` or `docker run -p 10000:10000 mcr.microsoft.com/azure-storage/azurite`).
# The values below are Azurite's well-known dev credentials — DO NOT use them in production.
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://127.0.0.1:10000/devstoreaccount1;

# Production example (uncomment + fill in to use real Azure):
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net

# Alternative: account + key instead of a full connection string.
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=

# Name of the container holding the skill tree (<category>/.../<name>/SKILL.md).
# The seed script creates it automatically; you can also pre-create it with:
#   az storage container create --name skills --connection-string "$AZURE_STORAGE_CONNECTION_STRING"
AZURE_STORAGE_CONTAINER=skills

# Override the x-ms-version header sent to Azure Blob Storage. Needed when the
# bundled SDK ships a service version newer than your Azurite supports — the
# error message will mention "API version YYYY-MM-DD is not supported by Azurite".
# Leave EMPTY in production (real Azure); set for local Azurite if needed.
# Recent stable choice: 2025-01-05 (works with Azurite >= 3.32).
AZURE_STORAGE_API_VERSION=2025-01-05

# --- Caching ---
# How long (seconds) to cache the parsed skill catalogue in memory. 0 disables.
CATALOGUE_TTL_SECONDS=60
